{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Torus Turbo",
  "version": "0.1.0",
  "identifier": "com.auroboros.torusturbo",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5172",
    "beforeDevCommand": "npm run dev -- --port 5172",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Torus Turbo",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": true,
        "visible": false,
        "transparent": true
      },
      {
        "label": "splash",
        "title": "Torus Turbo",
        "url": "splash.html",
        "width": 480,
        "height": 280,
        "resizable": false,
        "decorations": false,
        "transparent": false,
        "center": true,
        "alwaysOnTop": true,
        "backgroundColor": "#0c0d1e"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
